# PHP新闻管理系统 - 环境配置示例
# 复制此文件为 .env 并修改配置

# 应用环境
APP_ENV=production
APP_DEBUG=false
APP_VERSION=1.2.0

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=db_news
DB_CHARSET=utf8mb4

# Session配置
SESSION_LIFETIME=7200
SESSION_NAME=PHPSESSID

# 安全配置
CSRF_TOKEN_LIFETIME=7200
RATE_LIMIT_LOGIN=10
RATE_LIMIT_WINDOW=60

# 日志配置
LOG_LEVEL=info
LOG_MAX_FILE_SIZE=10485760
LOG_PATH=./logs

# 文件上传
UPLOAD_MAX_SIZE=52428800
UPLOAD_PATH=./uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,zip,rar,pdf

# 缓存配置
CACHE_ENABLED=true
CACHE_TTL=3600

# API配置
API_VERSION=v1
API_RATE_LIMIT=100
API_RATE_WINDOW=60
